      "id": "font_size",
      "label": "Font size",
      "min": 0,
      "max": 99,
      "step": 1,
      "default": 16
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text align",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "text_before_price",
      "label": "Text before price",
      "default": "<p>You're</p>"
    },
    {
      "type": "richtext",
      "id": "text_after_price",
      "label": "Text after price",
      "default": "<p>away from <strong>FREE SHIPPING!</strong></p>"
    }
  ],
  "presets": [
    { "name": "Shipping Progress" }
  ]
}
{% endschema %}
