{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
-%}

{% unless product_resource == blank %}
  {% render 'variant-main-picker', product_resource: product_resource, block: block %}
{% endunless %}

{% schema %}
{
  "name": "t:names.product_variant_picker",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Image-only variant picker. Upload up to 10 images and they will be applied to option values in order (1st value uses Image 1, 2nd value uses Image 2, etc.). If an image isn’t provided, it falls back to the variant’s featured image, then text."
    },

    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Image size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "image_gap",
      "label": "Gap between options",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 10
    },

    {
      "type": "header",
      "content": "Custom images (by order)"
    },
    {
      "type": "paragraph",
      "content": "These images are applied to option values in the order they appear. Example: the first option value uses Image 1, the second uses Image 2, and so on."
    },

    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_variant_picker",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
