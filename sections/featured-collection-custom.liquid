{%- liquid
  assign collection = section.settings.collection
  assign max_products = section.settings.max_products
  assign heading = section.settings.heading
  assign subheading_items = section.settings.subheading_items
-%}

<div
  class="fcc-section color-{{ section.settings.color_scheme }}"
  style="
    --fcc-pad-top: {{ section.settings.padding_top }}px;
    --fcc-pad-bottom: {{ section.settings.padding_bottom }}px;
    --fcc-card-radius: {{ section.settings.card_radius }}px;
  "
>
  <div class="fcc-inner section section--page-width">

    {%- if heading != blank or subheading_items != blank -%}
      <div class="fcc-header">
        {%- if heading != blank -%}
          <h2 class="fcc-heading">{{ heading }}</h2>
        {%- endif -%}

        {%- if subheading_items != blank -%}
          <ul class="fcc-subheading-list">
            {%- assign items = subheading_items | split: ',' -%}
            {%- for item in items -%}
              <li class="fcc-subheading-item">
                <span class="fcc-check-icon">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M11.6667 3.5L5.25 9.91667L2.33333 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                {{- item | strip -}}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if collection != blank and collection.products_count > 0 -%}
      {% capture list_items %}
        {%- for product in collection.products limit: max_products -%}
          {%- assign variant = product.selected_or_first_available_variant -%}
          <div class="resource-list__item">
            <div class="fcc-card">
              <a href="{{ product.url }}" class="fcc-card__media">
                {%- liquid
                  assign product_index = forloop.index
                  assign custom_img = nil
                  for block in section.blocks
                    if block.type == 'product_image' and block.settings.position == product_index
                      if block.settings.image != blank
                        assign custom_img = block.settings.image
                      endif
                      break
                    endif
                  endfor
                  assign card_image = custom_img | default: product.featured_image
                -%}
                {%- if card_image -%}
                  <img
                    src="{{ card_image | image_url: width: 600 }}"
                    srcset="
                      {{ card_image | image_url: width: 300 }} 300w,
                      {{ card_image | image_url: width: 450 }} 450w,
                      {{ card_image | image_url: width: 600 }} 600w
                    "
                    sizes="(max-width: 749px) 45vw, (max-width: 989px) 30vw, 25vw"
                    alt="{{ card_image.alt | default: product.title | escape }}"
                    loading="lazy"
                    width="{{ card_image.width }}"
                    height="{{ card_image.height }}"
                    class="fcc-card__img"
                  >
                {%- else -%}
                  <div class="fcc-card__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                {%- endif -%}

                {%- if product.available == false -%}
                  <span class="fcc-badge fcc-badge--soldout">{{ 'products.product.sold_out' | t }}</span>
                {%- elsif product.compare_at_price > product.price -%}
                  <span class="fcc-badge fcc-badge--sale">{{ 'products.product.on_sale' | t }}</span>
                {%- endif -%}
              </a>

              <div class="fcc-card__info">
                <div class="fcc-card__stars">
                  <div class="fcc-stars-fallback">{%- render 'star-wrapper' -%}</div>
                  <div class="fcc-stars-rio" style="display:none;">
                    <div
                      class="ruk_rating_snippet"
                      data-sku="{{ product.variants | map: 'sku' | reject: '' | join: ';' }}"
                    ></div>
                  </div>
                </div>

                <a href="{{ product.url }}" class="fcc-card__title">{{ product.title }}</a>

                <div class="fcc-card__price">
                  {%- render 'price', product_resource: product, show_sale_price_first: true -%}
                </div>

                <div class="fcc-card__bottom">
                  {%- assign u1 = product.metafields.custom.usp_1.value | default: '' | strip -%}
                  {%- assign u2 = product.metafields.custom.usp_2.value | default: '' | strip -%}
                  {%- assign u3 = product.metafields.custom.usp_3.value | default: '' | strip -%}

                  {%- if u1 != blank or u2 != blank or u3 != blank -%}
                    <ul class="fcc-usps">
                      {%- if u1 != blank -%}<li>{{ u1 | escape }}</li>{%- endif -%}
                      {%- if u2 != blank -%}<li>{{ u2 | escape }}</li>{%- endif -%}
                      {%- if u3 != blank -%}<li>{{ u3 | escape }}</li>{%- endif -%}
                    </ul>
                  {%- endif -%}

                  {%- if variant.available -%}
                    <product-form-component
                      data-section-id="{{ section.id }}"
                      data-product-id="{{ product.id }}"
                      on:submit="/handleSubmit"
                    >
                      <div class="visually-hidden" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
                      {%- form 'product', product, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                        <input type="hidden" name="id" ref="variantId" value="{{ variant.id }}">
                        {% render 'add-to-cart-button',
                          can_add_to_cart: true,
                          class: 'add-to-cart-button fcc-atc-btn',
                          product: product
                        %}
                      {%- endform -%}
                    </product-form-component>
                  {%- else -%}
                    <button type="button" class="fcc-atc-btn fcc-atc-btn--disabled" disabled>
                      {{ 'products.product.sold_out' | t }}
                    </button>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>

          {%- unless forloop.last -%}
            <!--@list/split-->
          {%- endunless -%}
        {%- endfor -%}
      {% endcapture %}

      {%- assign list_items_array = list_items | strip | split: '<!--@list/split-->' -%}

      {% render 'resource-list',
        list_items: list_items,
        list_items_array: list_items_array,
        settings: section.settings,
        carousel_ref: 'fccCarousel',
        slide_count: max_products,
        content_type: 'products',
        test_id: 'featured-collection-custom'
      %}
    {%- endif -%}
  </div>
</div>

<style>
  /* Section wrapper */
  .fcc-section {
    padding-top: var(--fcc-pad-top);
    padding-bottom: var(--fcc-pad-bottom);
  }

  .fcc-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Header */
  .fcc-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  .fcc-heading {
    margin: 0;
    font-size: 2.2rem;
    line-height: 1.15;
  }

  .fcc-subheading-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px 16px;
    font-size: 0.85rem;
  }

  .fcc-subheading-item {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .fcc-check-icon {
    display: flex;
    flex-shrink: 0;
  }

  /* Card */
  .fcc-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--fcc-card-radius);
    overflow: hidden;
    height: 100%;
  }

  /* Card media */
  .fcc-card__media {
    display: block;
    position: relative;
    overflow: hidden;
    border-radius: var(--fcc-card-radius);
  }

  .fcc-card__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }

  .fcc-card__placeholder {
    aspect-ratio: 1 / 1;
    background: var(--color-background);
  }

  .fcc-card__placeholder svg {
    width: 100%;
    height: 100%;
  }

  /* Badges */
  .fcc-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    padding: 4px 10px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: 4px;
  }

  .fcc-badge--soldout {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .fcc-badge--sale {
    background: #b5443a;
    color: #fff;
  }

  .fcc-card__stars {
    margin-bottom: 4px;
  }

  .fcc-card__stars svg {
    width: 16px;
    height: 16px;
  }

  .fcc-card__stars .ruk-rating-snippet-count {
    display: none;
  }

  .fcc-card__stars .ruk_rating_snippet {
    line-height: 1;
  }

  .fcc-card__stars .ruk-icon-percentage-star--100 {
    color: #f7d12f;
  }

  /* Card info */
  .fcc-card__info {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 10px 0 0;
    gap: 4px;
  }

  .fcc-card__title {
    font-size: 1.15rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-foreground);
    line-height: 1.3;
  }

  .fcc-card__title:hover {
    text-decoration: none;
  }

  .fcc-card__price {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 1rem;
    font-weight: 700;
  }

  .fcc-price--sale {
    color: #b5443a;
  }

  .fcc-price--compare {
    opacity: 0.5;
    font-weight: 400;
  }

  /* Bottom section - pushed to bottom */
  .fcc-card__bottom {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 14px;
  }

  /* USPs */
  .fcc-usps {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.82rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .fcc-usps li {
    position: relative;
    padding-left: 18px;
  }

  .fcc-usps li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 12px;
    height: 12px;
    background-color: currentColor;
    -webkit-mask-image: url("{{ 'icon-plus.svg' | asset_url }}");
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    -webkit-mask-size: 100% 100%;
    mask-image: url("{{ 'icon-plus.svg' | asset_url }}");
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: 100% 100%;
  }

  /* Add to cart button */
  .fcc-atc-btn {
    position: relative;
    overflow: hidden;
    width: fit-content;
    padding: 14px 24px;
    border: 1px solid #000;
    background: #000;
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
    cursor: pointer;
    border-radius: 8px;
    transition: opacity 0.2s ease;
    font-family: inherit;
    line-height: 1.4;
    white-space: nowrap;
    box-sizing: border-box;
  }

  /* Override buy-buttons.liquid styles that come with .add-to-cart-button class */
  .fcc-atc-btn.add-to-cart-button {
    height: auto;
    padding: 14px 24px;
  }

  .fcc-atc-btn .add-to-cart-icon svg {
    width: 18px;
    height: 18px;
  }

  .fcc-atc-btn[data-added='true'] {
    background: #2a7d6f;
    border-color: #2a7d6f;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .fcc-atc-btn:hover {
    opacity: 0.85;
  }

  .fcc-atc-btn--disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* Carousel arrows: position left/right outside cards */
  .fcc-section slideshow-arrows {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: 0;
  }

  .fcc-section slideshow-arrows .slideshow-control {
    pointer-events: auto;
  }

  /* Keep carousel within page width */
  .fcc-section .force-full-width {
    width: 100%;
    margin-left: 0;
    padding-left: 0;
    padding-right: 0;
  }

  /* Tablet: 3 columns */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .fcc-section .resource-list__carousel {
      --column-count: 3;
    }
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .fcc-heading {
      font-size: 1.8rem;
    }

    .fcc-card__title {
      font-size: 1rem;
    }

    .fcc-card__price {
      font-size: 0.88rem;
    }

    .fcc-usps {
      font-size: 0.75rem;
    }

    .fcc-card__stars svg {
      width: 14px;
      height: 14px;
    }

    .fcc-atc-btn {
      padding: 14px 24px;
      font-size: 0.75rem;
    }

    .fcc-subheading-list {
      font-size: 0.75rem;
      gap: 4px 12px;
    }
  }
</style>

<script>
  (function() {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;
    var maxAttempts = 40;
    var attempt = 0;

    function tryInit() {
      attempt++;
      if (typeof ratingSnippet === 'function' && typeof reviewsIoStore !== 'undefined') {
        ratingSnippet("ruk_rating_snippet", {
          store: reviewsIoStore,
          color: '#000000',
          textClr: '#333333',
          linebreak: false,
          usePolaris: true,
          text: 'Reviews',
          lang: 'en',
          mode: 'default',
          showEmptyStars: false,
          enableSyndication: false
        });
        /* After a short delay, check if Reviews.io populated any snippets and swap visibility */
        setTimeout(function() {
          var rios = section.querySelectorAll('.fcc-stars-rio .ruk_rating_snippet');
          rios.forEach(function(el) {
            if (el.innerHTML.trim().length > 0) {
              el.closest('.fcc-card__stars').querySelector('.fcc-stars-fallback').style.display = 'none';
              el.closest('.fcc-stars-rio').style.display = '';
            }
          });
        }, 1500);
      } else if (attempt < maxAttempts) {
        setTimeout(tryInit, 300);
      }
    }

    if (document.readyState === 'complete') {
      setTimeout(tryInit, 200);
    } else {
      window.addEventListener('load', function() { setTimeout(tryInit, 200); });
    }
  })();
</script>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Best Sellers"
    },
    {
      "type": "text",
      "id": "subheading_items",
      "label": "Subheading items (comma separated)",
      "default": "Sustainable made, Additive free, Bioavailable forms"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 5
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "carousel"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2",
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "mobile_card_size",
      "label": "Mobile card size",
      "options": [
        { "value": "60cqw", "label": "1 visible" },
        { "value": "44cqw", "label": "2 visible" }
      ],
      "default": "60cqw",
      "visible_if": "{{ section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "Gap",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "Row gap",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "header",
      "content": "Carousel navigation",
      "visible_if": "{{ section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "Arrow style",
      "options": [
        { "value": "arrow", "label": "Arrows" },
        { "value": "chevron", "label": "Chevrons" },
        { "value": "none", "label": "None" }
      ],
      "default": "arrow",
      "visible_if": "{{ section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "Arrow background",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" }
      ],
      "default": "none",
      "visible_if": "{{ section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "checkbox",
      "id": "carousel_on_mobile",
      "label": "Carousel on mobile (grid only)",
      "default": false,
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "product_image",
      "name": "Custom product image",
      "settings": [
        {
          "type": "range",
          "id": "position",
          "label": "Product position",
          "info": "Which product in the list (1 = first, 2 = second, etc.)",
          "min": 1,
          "max": 12,
          "step": 1,
          "default": 1
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
