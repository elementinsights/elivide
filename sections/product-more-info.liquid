      "min": 16,
      "max": 40,
      "step": 2,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "icon_right_offset",
      "label": "Icon right offset",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Accordion content",
      "default": "<h3>Product details</h3><p>Add your product description here. You can include headings, paragraphs, and lists.</p>"
    },
    {
      "type": "color",
      "id": "content_bg_color",
      "label": "Content background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "content_heading_color",
      "label": "Content heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "content_text_color",
