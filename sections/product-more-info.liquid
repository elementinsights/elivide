{% comment %}
  Product More Info Accordion Section
  - Full-width header bar with its own background
  - Centered title
  - Expandable content area with separate background
  - Configurable via theme editor
{% endcomment %}

{% style %}
  .more-info-section {
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .more-info-accordion {
    width: 100%;
    border: none;
  }

  .more-info-accordion__header {
    width: 100%;
    background-color: {{ section.settings.header_bg_color }};
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: {{ section.settings.header_padding_y }}px 40px;
    border: none;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    transition: background-color 0.2s ease;
  }

  .more-info-accordion__header:hover {
    background-color: {{ section.settings.header_bg_color_hover }};
  }

  .more-info-accordion__title {
    font-family: {{ section.settings.title_font | default: 'inherit' }};
    font-size: {{ section.settings.title_font_size }}px;
    font-weight: {{ section.settings.title_font_weight }};
    color: {{ section.settings.title_color }};
    text-align: center;
    margin: 0;
    letter-spacing: {{ section.settings.title_letter_spacing }}px;
    text-transform: {{ section.settings.title_text_transform }};
    line-height: 1.3;
  }

  .more-info-accordion__icon {
    position: absolute;
    right: {{ section.settings.icon_right_offset }}px;
    top: 50%;
    transform: translateY(-50%);
    font-size: {{ section.settings.icon_size }}px;
    font-weight: 300;
    color: {{ section.settings.icon_color }};
    line-height: 1;
    transition: transform 0.3s ease;
    user-select: none;
  }

  .more-info-accordion[open] .more-info-accordion__icon {
    transform: translateY(-50%) rotate(45deg);
  }

  .more-info-accordion__content {
    width: 100%;
    background-color: {{ section.settings.content_bg_color }};
    overflow: hidden;
    animation: accordion-open 0.35s ease forwards;
  }

  @keyframes accordion-open {
    from {
      opacity: 0;
      max-height: 0;
    }
    to {
      opacity: 1;
      max-height: 2000px;
    }
  }

  .more-info-accordion__content-inner {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.content_padding_y }}px {{ section.settings.content_padding_x }}px;
  }

  .more-info-accordion__content-inner h2,
  .more-info-accordion__content-inner h3,
  .more-info-accordion__content-inner h4 {
    color: {{ section.settings.content_heading_color }};
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .more-info-accordion__content-inner h2:first-child,
  .more-info-accordion__content-inner h3:first-child,
  .more-info-accordion__content-inner h4:first-child {
    margin-top: 0;
  }

  .more-info-accordion__content-inner p {
    color: {{ section.settings.content_text_color }};
    font-size: {{ section.settings.content_font_size }}px;
    line-height: {{ section.settings.content_line_height }};
    margin-bottom: 1em;
  }

  .more-info-accordion__content-inner ul,
  .more-info-accordion__content-inner ol {
    color: {{ section.settings.content_text_color }};
    font-size: {{ section.settings.content_font_size }}px;
    line-height: {{ section.settings.content_line_height }};
    padding-left: 1.5em;
    margin-bottom: 1em;
  }

  .more-info-accordion__content-inner li {
    margin-bottom: 0.35em;
  }

  /* Summary marker removal (cross-browser) */
  .more-info-accordion__header::-webkit-details-marker {
    display: none;
  }

  .more-info-accordion__header::marker {
    content: '';
    display: none;
  }

  @media screen and (max-width: 749px) {
    .more-info-accordion__title {
      font-size: {{ section.settings.title_font_size | minus: 4 }}px;
    }

    .more-info-accordion__content-inner {
      padding: {{ section.settings.content_padding_y | times: 0.7 | round }}px 20px;
    }

    .more-info-accordion__icon {
      right: 20px;
    }
  }
{% endstyle %}

<section class="more-info-section">
  <details class="more-info-accordion"{% if section.settings.open_by_default %} open{% endif %}>
    <summary class="more-info-accordion__header">
      <h2 class="more-info-accordion__title">{{ section.settings.title }}</h2>
      <span class="more-info-accordion__icon" aria-hidden="true">+</span>
    </summary>
    <div class="more-info-accordion__content">
      <div class="more-info-accordion__content-inner">
        {{ section.settings.content }}
      </div>
    </div>
  </details>
</section>

<script>
  // Smooth close animation
  document.querySelectorAll('.more-info-accordion').forEach(details => {
    const summary = details.querySelector('.more-info-accordion__header');
    const content = details.querySelector('.more-info-accordion__content');

    summary.addEventListener('click', (e) => {
      if (details.hasAttribute('open')) {
        e.preventDefault();
        content.style.animation = 'none';
        content.style.overflow = 'hidden';
        content.style.maxHeight = content.scrollHeight + 'px';
        requestAnimationFrame(() => {
          content.style.transition = 'max-height 0.3s ease, opacity 0.3s ease';
          content.style.maxHeight = '0';
          content.style.opacity = '0';
        });
        content.addEventListener('transitionend', () => {
          details.removeAttribute('open');
          content.style.transition = '';
          content.style.maxHeight = '';
          content.style.opacity = '';
          content.style.overflow = '';
          content.style.animation = '';
        }, { once: true });
      }
    });
  });
</script>

{% schema %}
{
  "name": "Product More Info",
  "tag": "section",
  "class": "product-more-info-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Accordion title",
      "default": "More Info"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title font size",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 22,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "label": "Title letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "title_text_transform",
      "label": "Title text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Header bar"
    },
    {
      "type": "color",
      "id": "header_bg_color",
      "label": "Header background",
      "default": "#faf5ec"
    },
    {
      "type": "color",
      "id": "header_bg_color_hover",
      "label": "Header background (hover)",
      "default": "#f5eedf"
    },
    {
      "type": "range",
      "id": "header_padding_y",
      "label": "Header vertical padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
