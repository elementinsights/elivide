{% comment %}
  Blog Article Section
  - Desktop: title+meta left / featured image right, then article body left / sticky product sidebar right
  - Mobile: stacked layout
  - Bottom bar with tags, author, print & share
  - Sidebar supports list of products via article metafield (custom.featured_product) with fallback to single section setting
{% endcomment %}
<div class="shopify-section section-wrapper section-blog-post">
  <div class="section section--page-width">
    <article class="blog-article" itemscope itemtype="http://schema.org/BlogPosting">
      {%- comment -%} HERO: Title + Featured Image {%- endcomment -%}
      <div class="blog-article__hero">
        <div class="blog-article__hero-content">
          <h1 class="blog-article__title" itemprop="headline">{{ article.title }}</h1>

          <p class="blog-article__byline" itemprop="author" itemscope itemtype="http://schema.org/Person">
            by <span itemprop="name">{{ article.author }}</span>
            {%- if section.settings.author_credentials != blank -%}
              {{ section.settings.author_credentials }}
            {%- endif -%}
            – <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
              {{ article.published_at | date: '%B %d, %Y' }}
            </time>
          </p>

          {%- if article.tags.size > 0 -%}
            <div class="blog-article__tags">
              {%- for tag in article.tags -%}
                <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="blog-article__tag">{{ tag }}</a>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="blog-article__breadcrumb-row">
            <nav class="blog-article__breadcrumbs" aria-label="Breadcrumb">
              <a href="/" class="blog-article__breadcrumb-link" aria-label="Home">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
              </a>
              <span class="blog-article__breadcrumb-sep">›</span>
              <a href="{{ blog.url }}" class="blog-article__breadcrumb-link">{{ blog.title }}</a>
              <span class="blog-article__breadcrumb-sep">›</span>
              <span class="blog-article__breadcrumb-current">{{ article.title | truncate: 35 }}</span>
            </nav>

            <div class="blog-article__actions">
              <button class="blog-article__action-btn" onclick="window.print()" aria-label="Print">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
              </button>
              <button class="blog-article__action-btn" onclick="if(navigator.share){navigator.share({title:document.title,url:window.location.href})}else{navigator.clipboard.writeText(window.location.href);this.setAttribute('data-copied','true');setTimeout(()=>this.removeAttribute('data-copied'),2000)}" aria-label="Share">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
              </button>
            </div>
          </div>
        </div>

        {%- if article.image -%}
          <div class="blog-article__hero-image">
            <img
              src="{{ article.image | image_url: width: 800 }}"
              srcset="
                {{ article.image | image_url: width: 400 }} 400w,
                {{ article.image | image_url: width: 600 }} 600w,
                {{ article.image | image_url: width: 800 }} 800w
              "
              sizes="(max-width: 989px) 100vw, 45vw"
              alt="{{ article.image.alt | escape }}"
              loading="eager"
              width="{{ article.image.width }}"
              height="{{ article.image.height }}"
              class="blog-article__featured-img"
              itemprop="image"
            >
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} BODY: Article Content + Sticky Sidebar {%- endcomment -%}
      <div class="blog-article__body-wrapper">
        <div class="blog-article__content" itemprop="articleBody">
          {{ article.content }}
        </div>

        {%- assign sidebar_products = article.metafields.custom.featured_product.value -%}
        {%- if sidebar_products != blank or section.settings.sidebar_product != blank -%}
          <aside class="blog-article__sidebar">
            <div class="blog-article__sidebar-inner">
              <p class="blog-article__sidebar-title">{{ section.settings.sidebar_heading }}</p>

              {%- if sidebar_products != blank -%}
                {%- for product in sidebar_products -%}
                  <div class="blog-article__product-card">
                    {%- if product.featured_image -%}
                      <a href="{{ product.url }}" class="blog-article__product-image-link">
                        <img
                          src="{{ product.featured_image | image_url: width: 500 }}"
                          srcset="
                            {{ product.featured_image | image_url: width: 300 }} 300w,
                            {{ product.featured_image | image_url: width: 500 }} 500w
                          "
                          sizes="280px"
                          alt="{{ product.featured_image.alt | escape }}"
                          loading="lazy"
                          class="blog-article__product-img"
                          width="auto"
                          height="auto"
                        >
                      </a>
                    {%- endif -%}
                    <div class="blog-article__product-info">
                      <a href="{{ product.url }}" class="blog-article__product-name">{{ product.title }}</a>
                      {%- if product.metafields.reviews.rating.value -%}
                        {%- assign rating = product.metafields.reviews.rating.value.rating | round -%}
                        <div class="blog-article__product-stars" aria-label="{{ rating }} out of 5 stars">
                          {%- for i in (1..5) -%}
                            {%- if i <= rating -%}
                              <svg width="18" height="18" viewBox="0 0 24 24" fill="#d4a017" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            {%- else -%}
                              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d4a017" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            {%- endif -%}
                          {%- endfor -%}
                        </div>
                      {%- elsif section.settings.show_stars -%}
                        <div class="blog-article__product-stars" aria-label="5 out of 5 stars">
                          {%- for i in (1..5) -%}
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="#d4a017" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                          {%- endfor -%}
                        </div>
                      {%- endif -%}
                      <div class="blog-article__product-price-row">
                        <span class="blog-article__product-price">{{ product.price | money }}</span>
                        <a href="{{ product.url }}" class="blog-article__product-view-btn">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
                          View product
                        </a>
                      </div>
                    </div>
                  </div>
                {%- endfor -%}

              {%- else -%}
                {%- assign product = section.settings.sidebar_product -%}
                <div class="blog-article__product-card">
                  {%- if product.featured_image -%}
                    <a href="{{ product.url }}" class="blog-article__product-image-link">
                      <img
                        src="{{ product.featured_image | image_url: width: 500 }}"
                        srcset="
                          {{ product.featured_image | image_url: width: 300 }} 300w,
                          {{ product.featured_image | image_url: width: 500 }} 500w
                        "
                        sizes="280px"
                        alt="{{ product.featured_image.alt | escape }}"
                        loading="lazy"
                        class="blog-article__product-img"
                        width="auto"
                        height="auto"
                      >
                    </a>
                  {%- endif -%}
                  <div class="blog-article__product-info">
                    <a href="{{ product.url }}" class="blog-article__product-name">{{ product.title }}</a>
                    {%- if product.metafields.reviews.rating.value -%}
                      {%- assign rating = product.metafields.reviews.rating.value.rating | round -%}
                      <div class="blog-article__product-stars" aria-label="{{ rating }} out of 5 stars">
                        {%- for i in (1..5) -%}
                          {%- if i <= rating -%}
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="#d4a017" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                          {%- else -%}
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d4a017" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- elsif section.settings.show_stars -%}
                      <div class="blog-article__product-stars" aria-label="5 out of 5 stars">
                        {%- for i in (1..5) -%}
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="#d4a017" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                    <div class="blog-article__product-price-row">
                      <span class="blog-article__product-price">{{ product.price | money }}</span>
                      <a href="{{ product.url }}" class="blog-article__product-view-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
                        View product
                      </a>
                    </div>
                  </div>
                </div>
              {%- endif -%}

            </div>
          </aside>
        {%- endif -%}
      </div>

      {%- comment -%} BOTTOM BAR {%- endcomment -%}
      <div class="blog-article__bottom-bar">
        <div class="blog-article__bottom-bar-inner">
          {%- if article.tags.size > 0 -%}
            <div class="blog-article__tags">
              {%- for tag in article.tags -%}
                <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="blog-article__tag">{{ tag }}</a>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <p class="blog-article__bottom-byline">
            by {{ article.author }}
            {%- if section.settings.author_credentials != blank -%}
              {{ section.settings.author_credentials }}
            {%- endif -%}
            – {{ article.published_at | date: '%B %d, %Y' }}
          </p>

          <div class="blog-article__actions">
            <button class="blog-article__action-btn" onclick="window.print()" aria-label="Print">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
            </button>
            <button class="blog-article__action-btn" onclick="if(navigator.share){navigator.share({title:document.title,url:window.location.href})}else{navigator.clipboard.writeText(window.location.href)}" aria-label="Share">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
            </button>
          </div>
        </div>
      </div>
      {%- comment -%} RELATED POSTS {%- endcomment -%}
      {%- if section.settings.show_related_posts -%}
        <div class="blog-article__related">
          <h2 class="blog-article__related-heading">{{ section.settings.related_heading }}</h2>
          <div class="blog-article__related-grid">
            {%- assign current_handle = article.handle -%}
            {%- assign count = 0 -%}
            {%- for post in blog.articles -%}
              {%- if post.handle != current_handle and count < 4 -%}
                {%- assign count = count | plus: 1 -%}
                <a href="{{ post.url }}" class="blog-article__related-card">
                  {%- if post.image -%}
                    <div class="blog-article__related-img-wrap">
                      <img
                        src="{{ post.image | image_url: width: 600 }}"
                        srcset="
                          {{ post.image | image_url: width: 300 }} 300w,
                          {{ post.image | image_url: width: 600 }} 600w
                        "
                        sizes="(max-width: 749px) 100vw, (max-width: 989px) 50vw, 25vw"
                        alt="{{ post.image.alt | escape }}"
                        loading="lazy"
                        class="blog-article__related-img"
                        width="auto"
                        height="auto"
                      >
                    </div>
                  {%- endif -%}
                  <div class="blog-article__related-info">
                    <h3 class="blog-article__related-title">{{ post.title }}</h3>
                    <p class="blog-article__related-excerpt">{{ post.excerpt_or_content | strip_html | truncate: 120 }}</p>
                    <span class="blog-article__related-link">Read more</span>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
      {%- comment -%} COMMENTS (optional) {%- endcomment -%}
      {%- if blog.comments_enabled? and section.settings.show_comments -%}
        <div class="blog-article__comments">
          {%- if article.comments_count > 0 -%}
            <h3>{{ 'blogs.article.comments' | t }} ({{ article.comments_count }})</h3>
            {%- for comment in article.comments -%}
              <div class="blog-article__comment">
                <p class="blog-article__comment-author">{{ comment.author }}</p>
                <p class="blog-article__comment-date">{{ comment.created_at | date: '%B %d, %Y' }}</p>
                {{ comment.content }}
              </div>
            {%- endfor -%}

            {%- if paginate.pages > 1 -%}
              {{ paginate | default_pagination }}
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </article>
  </div>
</div>

{% stylesheet %}
  /* ========================================
     BLOG ARTICLE SECTION
     ======================================== */

  /* --- HERO --- */
  .blog-article__hero {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 40px 0 32px;
  }

  @media screen and (min-width: 990px) {
    .blog-article__hero {
      flex-direction: row;
      align-items: flex-start;
      gap: 60px;
      padding: 60px 0 40px;
    }

    .blog-article__hero-content {
      flex: 1 1 55%;
      min-width: 0;
    }

    .blog-article__hero-image {
      flex: 0 0 40%;
      max-width: 40%;
    }
  }

  .blog-article__title {
    font-size: 32px;
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 16px 0;
    letter-spacing: -0.02em;
  }

  @media screen and (min-width: 750px) {
    .blog-article__title {
      font-size: 44px;
    }
  }

  .blog-article__byline {
    font-size: 12px;
    color: #555;
    margin: 0 0 16px 0;
    line-height: 1.5;
  }

  /* Tags */
  .blog-article__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .blog-article__tag {
    display: inline-block;
    padding: 6px 16px;
    background-color: #fce0a8;
    color: #1a1a1a;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .blog-article__tag:hover {
    background-color: #e7e6e6;
  }

  /* Breadcrumbs + Actions row */
  .blog-article__breadcrumb-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    overflow: hidden;
  }

  .blog-article__breadcrumbs {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: #555;
    white-space: nowrap;
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
    min-width: 0;
    flex: 1 1 0%;
  }

  .blog-article__breadcrumbs::-webkit-scrollbar {
    display: none;
  }

  .blog-article__breadcrumb-link {
    color: #1a1a1a;
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .blog-article__breadcrumb-link:hover {
    text-decoration: underline;
  }

  .blog-article__breadcrumb-sep {
    color: #999;
    font-size: 16px;
  }

  .blog-article__breadcrumb-current {
    color: #777;
  }

  .blog-article__actions {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .blog-article__action-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    color: #1a1a1a;
    display: flex;
    align-items: center;
    border-radius: 4px;
    transition: background-color 0.2s;
  }

  .blog-article__action-btn:hover {
    background-color: #f0f0f0;
  }

  /* Featured image */
.blog-article__featured-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
    object-fit: cover;
    aspect-ratio: 5/3;
  }

  /* --- BODY WRAPPER --- */
  .blog-article__body-wrapper {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-bottom: 40px;
  }

  @media screen and (min-width: 990px) {
    .blog-article__body-wrapper {
      flex-direction: row;
      gap: 60px;
      align-items: flex-start;
    }

    .blog-article__content {
      flex: 1 1 0%;
      min-width: 0;
    }

    .blog-article__sidebar {
      flex: 0 0 300px;
      position: sticky;
      top: 24px;
    }
  }

  /* Article content typography */
  .blog-article__content {
    font-size: 17px;
    line-height: 1.75;
    color: #1a1a1a;
  }

  .blog-article__content h2 {
    font-size: 28px;
    font-weight: 700;
    margin: 40px 0 16px;
    line-height: 1.2;
  }

  .blog-article__content h3 {
    font-size: 22px;
    font-weight: 700;
    margin: 32px 0 12px;
    line-height: 1.3;
  }

  .blog-article__content p {
    margin: 0 0 20px;
  }

  .blog-article__content a {
    color: #1a1a1a;
    text-decoration: underline;
  }

  .blog-article__content ul,
  .blog-article__content ol {
    margin: 0 0 20px 20px;
    padding: 0;
  }

  .blog-article__content li {
    margin-bottom: 6px;
  }

  .blog-article__content li::marker {
    color: #999;
  }

  .blog-article__content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 24px 0;
  }

  /* --- SIDEBAR --- */
  .blog-article__sidebar-inner {
    background-color: transparent;
  }

  .blog-article__sidebar-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 16px 0;
  }

  .blog-article__product-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #eee;
    background: #fff;
  }

  .blog-article__product-card + .blog-article__product-card {
    margin-top: 16px;
  }

  .blog-article__product-image-link {
    display: block;
  }

  .blog-article__product-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 12/9;
    background-color: #d5ebe0;
  }

  .blog-article__product-info {
    padding: 16px;
  }

  .blog-article__product-name {
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
    display: block;
    margin-bottom: 8px;
    line-height: 1.35;
  }

  .blog-article__product-name:hover {
    text-decoration: underline;
  }

  .blog-article__product-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 12px;
  }

  .blog-article__product-price-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .blog-article__product-price {
    font-size: 16px;
    font-weight: 600;
  }

  .blog-article__product-view-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: #555;
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 24px;
    transition: all 0.2s;
    white-space: nowrap;
    background: #fce0a8;
  }

  .blog-article__product-view-btn:hover {
    background: #e7e6e6;
  }

  /* --- BOTTOM BAR --- */
  .blog-article__bottom-bar {
    background-color: #f5f5f5;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 40px;
  }

  .blog-article__bottom-bar-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .blog-article__bottom-bar-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .blog-article__bottom-bar .blog-article__tags {
      margin-bottom: 0;
      flex: 0 1 auto;
    }
  }

  .blog-article__bottom-byline {
    font-size: 14px;
    color: #555;
    margin: 0;
    text-align: center;
    line-height: 1.5;
  }

  /* --- COMMENTS --- */
  .blog-article__comments {
    padding-bottom: 60px;
  }

  .blog-article__comment {
    border-bottom: 1px solid #eee;
    padding: 20px 0;
  }

  .blog-article__comment-author {
    font-weight: 600;
    margin: 0 0 4px;
  }

  .blog-article__comment-date {
    font-size: 13px;
    color: #888;
    margin: 0 0 8px;
  }

  /* --- PRINT --- */
  @media print {
    .blog-article__sidebar,
    .blog-article__actions,
    .blog-article__bottom-bar {
      display: none !important;
    }
  }

  /* --- RELATED POSTS --- */
  .blog-article__related {
    padding-bottom: 60px;
  }

  .blog-article__related-heading {
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 24px 0;
  }

  .blog-article__related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media screen and (min-width: 750px) {
    .blog-article__related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .blog-article__related-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .blog-article__related-card {
    display: flex;
    flex-direction: column;
    border: 1px solid #eee;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s;
  }

  .blog-article__related-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .blog-article__related-img-wrap {
    overflow: hidden;
  }

  .blog-article__related-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 16/10;
    transition: transform 0.3s;
  }

  .blog-article__related-card:hover .blog-article__related-img {
    transform: scale(1.03);
  }

  .blog-article__related-info {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-article__related-meta {
    font-size: 12px;
    color: #888;
    margin: 0 0 8px 0;
    line-height: 1.4;
  }

  .blog-article__related-title {
    font-size: 17px;
    font-weight: 700;
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .blog-article__related-excerpt {
    font-size: 14px;
    color: #555;
    margin: 0 0 16px 0;
    line-height: 1.5;
    flex: 1;
  }

  .blog-article__related-link {
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    padding-top: 12px;
    border-top: 1px solid #eee;
  }
{% endstylesheet %}

