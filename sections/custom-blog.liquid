{% comment %}
  Custom Blog Carousel Section
  - Horizontal scroll + snap (mobile-friendly)
  - Optional arrows (desktop)
{% endcomment %}

<div class="shopify-section section-wrapper bcx" id="bcx-{{ section.id }}">
    <div class="section section--page-width">
        <div class="custom-section-content">
            <div class="bcx__header">
                {% if section.settings.heading != blank %}
                <h2 class="bcx__title">{{ section.settings.heading | escape }}</h2>
                {% endif %}

                {% if section.settings.show_view_all and section.settings.blog != blank %}
                <a class="bcx__viewall" href="{{ section.settings.blog.url }}">View all</a>
                {% endif %}
            </div>

            {% assign blog_handle = section.settings.blog %}
            {% if blog_handle == blank %}
                <div class="bcx__empty">Select a blog in the section settings.</div>
            {% else %}
                {% assign articles = blog_handle.articles %}
                <div class="bcx__wrap">
                <button class="bcx__arrow bcx__arrow--left" type="button" aria-label="Scroll left">
                    ‹
                </button>

                <div class="bcx__track" data-track>
                    {% for article in articles limit: section.settings.limit %}
                    <article class="bcx__card">
                        <a class="bcx__cardlink" href="{{ article.url }}">
                        <div class="bcx__media">
                            {% if article.image %}
                            {{ article.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'bcx__img', alt: article.image.alt | default: article.title | escape }}
                            {% else %}
                            <div class="bcx__placeholder"></div>
                            {% endif %}
                        </div>

                        <div class="bcx__content">
                            <h3 class="bcx__cardtitle">{{ article.title }}</h3>

                            {% if section.settings.show_meta %}
                            <div class="bcx__meta">
                                <span class="bcx__date">{{ article.published_at | date: "%B %d, %Y" }}</span>
                                {% if article.author != blank %}
                                <span class="bcx__dot">•</span>
                                <span class="bcx__author">{{ article.author }}</span>
                                {% endif %}
                            </div>
                            {% endif %}

                            {% if section.settings.show_excerpt %}
                            <p class="bcx__excerpt">
                                {{ article.excerpt_or_content | strip_html | truncate: section.settings.excerpt_chars }}
                            </p>
                            {% endif %}
                        </div>
                        </a>
                    </article>
                    {% endfor %}
                </div>

                <button class="bcx__arrow bcx__arrow--right" type="button" aria-label="Scroll right">
                    ›
                </button>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
  /* Scope everything to this section instance */
  #bcx-{{ section.id }} {
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    background: {{ section.settings.bg }};
    color: {{ section.settings.text }};
  }

  #bcx-{{ section.id }} .bcx__header{
    display:flex;
    align-items:baseline;
    justify-content:space-between;
    gap:16px;
    margin-bottom:16px;
  }

  #bcx-{{ section.id }} .bcx__title{
    margin:0;
    font-size: clamp(22px, 2vw, 34px);
    line-height:1.15;
  }

  #bcx-{{ section.id }} .bcx__viewall{
    color: inherit;
    opacity: .85;
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
  }

  #bcx-{{ section.id }} .bcx__empty{
    opacity: .8;
    padding: 16px 0;
  }

  #bcx-{{ section.id }} .bcx__wrap{
    position: relative;
  }

  /* The “carousel” */
  #bcx-{{ section.id }} .bcx__track{
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(260px, {{ section.settings.card_width }}px);
    gap: {{ section.settings.gap }}px;

    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;

    padding-bottom: 8px;
  }

  #bcx-{{ section.id }} .bcx__track::-webkit-scrollbar{
    height: 8px;
  }

  #bcx-{{ section.id }} .bcx__card{
    scroll-snap-align: start;
    border-radius: {{ section.settings.radius }}px;
    overflow: hidden;
    background: {{ section.settings.card_bg }};
    border: 1px solid rgba(255,255,255,.12);
  }

  #bcx-{{ section.id }} .bcx__cardlink{
    display:block;
    color: inherit;
    text-decoration: none;
  }

  #bcx-{{ section.id }} .bcx__media{
    aspect-ratio: 4/3;
    background: rgba(255,255,255,.06);
  }

  #bcx-{{ section.id }} .bcx__img{
    width:100%;
    height:100%;
    object-fit: cover;
    display:block;
  }

  #bcx-{{ section.id }} .bcx__placeholder{
    width:100%;
    height:100%;
    background: rgba(255,255,255,.08);
  }

  #bcx-{{ section.id }} .bcx__content{
    padding: 16px 0;
  }

  /* IMPORTANT: allow wrapping; do NOT clamp by default */
  #bcx-{{ section.id }} .bcx__cardtitle{
    margin: 0 0 10px;
    font-size: 22px;
    line-height: 1.2;
    white-space: normal;
    overflow: visible;
    word-break: break-word;
  }

  #bcx-{{ section.id }} .bcx__meta{
    display:flex;
    flex-wrap: wrap;
    gap: 8px;
    opacity: .85;
    font-size: 14px;
    line-height: 1.2;
    margin-bottom: 10px;
  }

  #bcx-{{ section.id }} .bcx__dot{ opacity: .7; }

  #bcx-{{ section.id }} .bcx__excerpt{
    margin: 0;
    font-size: 16px;
    opacity: .9;
    line-height: 1.5;
  }

  /* Arrow buttons (desktop) */
  #bcx-{{ section.id }} .bcx__arrow{
    position:absolute;
    top: 38%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.18);
    background: rgba(0,0,0,.35);
    color: {{ section.settings.text }};
    cursor:pointer;
    display:none;
    align-items:center;
    justify-content:center;
    font-size: 26px;
    line-height: 1;
    backdrop-filter: blur(6px);
  }

  #bcx-{{ section.id }} .bcx__arrow--left{ left: -8px; }
  #bcx-{{ section.id }} .bcx__arrow--right{ right: -8px; }

  @media (min-width: 900px){
    #bcx-{{ section.id }} .bcx__arrow{ display:flex; }
  }

  /* A little nicer on small screens */
  @media (max-width: 480px){
    #bcx-{{ section.id }} .bcx__content{ padding: 14px; }
    #bcx-{{ section.id }} .bcx__cardtitle{ font-size: 20px; }
  }
</style>

<script>
  (function(){
    const root = document.getElementById("bcx-{{ section.id }}");
    if (!root) return;

    const track = root.querySelector("[data-track]");
    const left = root.querySelector(".bcx__arrow--left");
    const right = root.querySelector(".bcx__arrow--right");
    if (!track || !left || !right) return;

    function scrollByCard(dir){
      const firstCard = track.querySelector(".bcx__card");
      const cardWidth = firstCard ? firstCard.getBoundingClientRect().width : 300;
      const gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap || 0) || 0;
      track.scrollBy({ left: dir * (cardWidth + gap), behavior: "smooth" });
    }

    left.addEventListener("click", () => scrollByCard(-1));
    right.addEventListener("click", () => scrollByCard(1));
  })();
</script>

{% schema %}
{
  "name": "Blog carousel (custom)",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Articles" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "limit", "label": "Number of posts", "min": 2, "max": 12, "step": 1, "default": 8 },

    { "type": "checkbox", "id": "show_meta", "label": "Show date/author", "default": true },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show excerpt", "default": true },
    { "type": "range", "id": "excerpt_chars", "label": "Excerpt length (chars)", "min": 60, "max": 260, "step": 10, "default": 140 },

    { "type": "checkbox", "id": "show_view_all", "label": "Show “View all” link", "default": true },

    { "type": "range", "id": "card_width", "label": "Card width (px)", "min": 260, "max": 520, "step": 10, "default": 360 },
    { "type": "range", "id": "gap", "label": "Gap (px)", "min": 8, "max": 32, "step": 2, "default": 18 },
    { "type": "range", "id": "radius", "label": "Corner radius (px)", "min": 0, "max": 28, "step": 2, "default": 16 },

    { "type": "color", "id": "bg", "label": "Background", "default": "#000000" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#000000" },
    { "type": "color", "id": "text", "label": "Text", "default": "#ffffff" },

    { "type": "range", "id": "padding_y", "label": "Padding top/bottom (px)", "min": 0, "max": 80, "step": 4, "default": 28 },
    { "type": "range", "id": "padding_x", "label": "Padding left/right (px)", "min": 0, "max": 80, "step": 4, "default": 20 }
  ],
  "presets": [
    { "name": "Blog carousel (custom)" }
  ]
}
{% endschema %}
