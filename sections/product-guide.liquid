{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="pg-section section section--page-width color-{{ section.settings.color_scheme }}"
  style="
    --pg-pad-top: {{ section.settings.padding_top }}px;
    --pg-pad-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="pg-wrap">
    {%- if heading != blank or subheading != blank -%}
      <div class="pg-header">
        {%- if heading != blank -%}
          <h2 class="pg-heading">{{ heading }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="pg-subheading">{{ subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="pg-selector">
        {%- for block in section.blocks -%}
          {%- assign p = block.settings.product -%}
          {%- if p != blank -%}
            <button
              class="pg-thumb{% if forloop.first %} pg-thumb--active{% endif %}"
              data-pg-tab="{{ forloop.index0 }}"
              data-pg-section="{{ section.id }}"
            >
              <span class="pg-thumb__img-wrap">
                {%- if p.featured_image -%}
                  <img
                    src="{{ p.featured_image | image_url: width: 160 }}"
                    alt="{{ p.featured_image.alt | escape }}"
                    loading="lazy"
                    class="pg-thumb__img"
                    width="80"
                    height="80"
                  >
                {%- endif -%}
              </span>
              <span class="pg-thumb__text">
                <span class="pg-thumb__goal">{{ block.settings.goal | default: p.title }}</span>
              </span>
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="pg-panels">
        {%- for block in section.blocks -%}
          {%- assign p = block.settings.product -%}
          {%- if p != blank -%}
            <div
              class="pg-panel{% if forloop.first %} pg-panel--active{% endif %}"
              data-pg-panel="{{ forloop.index0 }}"
              data-pg-section="{{ section.id }}"
              {{ block.shopify_attributes }}
            >
              <div class="pg-panel__left">
                <div class="pg-panel__img-container">
                  {%- if p.featured_image -%}
                    <img
                      src="{{ p.featured_image | image_url: width: 800 }}"
                      srcset="
                        {{ p.featured_image | image_url: width: 500 }} 500w,
                        {{ p.featured_image | image_url: width: 650 }} 650w,
                        {{ p.featured_image | image_url: width: 800 }} 800w
                      "
                      sizes="(max-width: 749px) 90vw, 45vw"
                      alt="{{ p.featured_image.alt | escape }}"
                      loading="lazy"
                      width="{{ p.featured_image.width }}"
                      height="{{ p.featured_image.height }}"
                      class="pg-panel__img"
                    >
                  {%- endif -%}

                  {%- if block.settings.badge != blank -%}
                    <span class="pg-panel__badge">{{ block.settings.badge }}</span>
                  {%- endif -%}
                </div>
              </div>

              <div class="pg-panel__right">
                {%- if block.settings.goal != blank -%}
                  <span class="pg-panel__goal">{{ block.settings.goal }}</span>
                {%- endif -%}

                <h3 class="pg-panel__name">{{ p.title }}</h3>

                <div class="pg-panel__stars">
                  {%- render 'star-wrapper' -%}
                  <span class="pg-panel__review-count">200+ reviews</span>
                </div>

                {%- if block.settings.description != blank -%}
                  <p class="pg-panel__desc">{{ block.settings.description }}</p>
                {%- endif -%}

                {%- if block.settings.benefit_1 != blank or block.settings.benefit_2 != blank or block.settings.benefit_3 != blank -%}
                  <ul class="pg-panel__benefits">
                    {%- if block.settings.benefit_1 != blank -%}<li>{{ block.settings.benefit_1 }}</li>{%- endif -%}
                    {%- if block.settings.benefit_2 != blank -%}<li>{{ block.settings.benefit_2 }}</li>{%- endif -%}
                    {%- if block.settings.benefit_3 != blank -%}<li>{{ block.settings.benefit_3 }}</li>{%- endif -%}
                  </ul>
                {%- endif -%}

                <div class="pg-panel__actions">
                  <a href="{{ p.url }}" class="pg-panel__btn-primary">
                    Shop Now
                  </a>
                  <a href="{{ p.url }}" class="pg-panel__btn-secondary">
                    Learn More
                  </a>
                </div>

                <div class="pg-panel__price">
                  From {%- render 'price', product_resource: p, show_sale_price_first: true -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .pg-section {
    padding-top: var(--pg-pad-top);
    padding-bottom: var(--pg-pad-bottom);
  }

  .pg-wrap {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Header */
  .pg-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
  }

  .pg-heading {
    margin: 0;
    font-size: 2rem;
    line-height: 1.15;
  }

  .pg-subheading {
    margin: 0;
    font-size: 0.88rem;
    opacity: 0.55;
    line-height: 1.5;
    max-width: 500px;
  }

  /* Thumbnail selector */
  .pg-selector {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  .pg-thumb {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 16px 10px;
    border: 2px solid rgba(0, 0, 0, 0.06);
    background: transparent;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
    color: var(--color-foreground);
  }

  .pg-thumb:hover {
    border-color: rgba(0, 0, 0, 0.18);
    background: rgba(0, 0, 0, 0.015);
  }

  .pg-thumb--active {
    border-color: #2a7d6f;
    background: #f0faf7;
  }

  .pg-thumb--active:hover {
    border-color: #2a7d6f;
    background: #f0faf7;
  }

  .pg-thumb__img-wrap {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    background: #f5f4f1;
    flex-shrink: 0;
  }

  .pg-thumb__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pg-thumb__goal {
    font-size: 0.88rem;
    font-weight: 700;
    text-align: center;
    line-height: 1.3;
  }

  /* Panels */
  .pg-panels {
    position: relative;
  }

  .pg-panel {
    display: none;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    background: #f7f6f3;
    border-radius: 16px;
    overflow: hidden;
    min-height: 340px;
  }

  .pg-panel--active {
    display: grid;
  }

  /* Panel left - image */
  .pg-panel__left {
    height: 100%;
    position: relative;
  }

  .pg-panel__img-container {
    position: relative;
    height: 100%;
  }

  .pg-panel__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 340px;
  }

  .pg-panel__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 6px 14px;
    background: #2a7d6f;
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 6px;
  }

  /* Panel right - content */
  .pg-panel__right {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 28px 32px;
  }

  .pg-panel__goal {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #2a7d6f;
  }

  .pg-panel__name {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .pg-panel__stars {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pg-panel__review-count {
    font-size: 0.72rem;
    opacity: 0.45;
    font-weight: 500;
  }

  .pg-panel__desc {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.6;
    opacity: 0.6;
  }

  .pg-panel__benefits {
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .pg-panel__benefits li {
    font-size: 0.85rem;
    line-height: 1.4;
    padding-left: 24px;
    position: relative;
    font-weight: 500;
  }

  .pg-panel__benefits li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 15px;
    height: 15px;
    background-image: url("data:image/svg+xml,%3Csvg width='14' height='14' viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11.6667 3.5L5.25 9.91667L2.33333 7' stroke='%232a7d6f' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-size: contain;
  }

  /* Actions */
  .pg-panel__actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 6px;
  }

  .pg-panel__btn-primary {
    display: inline-block;
    padding: 14px 32px;
    background: #000;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    border-radius: 8px;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .pg-panel__btn-primary:hover {
    opacity: 0.85;
  }

  .pg-panel__btn-secondary {
    display: inline-block;
    padding: 14px 24px;
    background: transparent;
    color: #000;
    border: 1.5px solid rgba(0, 0, 0, 0.15);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .pg-panel__btn-secondary:hover {
    border-color: rgba(0, 0, 0, 0.4);
  }

  .pg-panel__price {
    font-size: 0.82rem;
    opacity: 0.5;
    margin-top: 2px;
  }

  /* Tablet */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .pg-thumb__img-wrap {
      width: 46px;
      height: 46px;
    }

    .pg-thumb {
      padding: 12px 8px;
      gap: 8px;
    }

    .pg-thumb__goal {
      font-size: 0.68rem;
    }

    .pg-panel {
      min-height: 360px;
    }

    .pg-panel__img {
      min-height: 360px;
    }

    .pg-panel__right {
      padding: 28px;
      gap: 8px;
    }

    .pg-panel__name {
      font-size: 1.3rem;
    }

    .pg-panel__desc {
      font-size: 0.82rem;
    }

    .pg-panel__benefits li {
      font-size: 0.78rem;
    }
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .pg-heading {
      font-size: 1.6rem;
    }

    .pg-selector {
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }

    .pg-thumb {
      padding: 10px 6px;
      gap: 6px;
      border-radius: 10px;
    }

    .pg-thumb__img-wrap {
      width: 40px;
      height: 40px;
    }

    .pg-thumb__goal {
      font-size: 0.6rem;
    }

    .pg-panel {
      grid-template-columns: 1fr;
      min-height: auto;
      border-radius: 12px;
    }

    .pg-panel__img {
      min-height: 240px;
      aspect-ratio: 4 / 3;
    }

    .pg-panel__right {
      padding: 20px;
      gap: 8px;
    }

    .pg-panel__name {
      font-size: 1.2rem;
    }

    .pg-panel__desc {
      font-size: 0.8rem;
    }

    .pg-panel__benefits li {
      font-size: 0.78rem;
      padding-left: 20px;
    }

    .pg-panel__benefits li::before {
      width: 13px;
      height: 13px;
    }

    .pg-panel__btn-primary,
    .pg-panel__btn-secondary {
      padding: 12px 20px;
      font-size: 0.72rem;
    }

    .pg-panel__actions {
      gap: 8px;
    }
  }
</style>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var tabs = document.querySelectorAll('[data-pg-tab][data-pg-section="' + sectionId + '"]');
    var panels = document.querySelectorAll('[data-pg-panel][data-pg-section="' + sectionId + '"]');

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var idx = this.getAttribute('data-pg-tab');

        tabs.forEach(function(t) {
          t.classList.remove('pg-thumb--active');
        });
        this.classList.add('pg-thumb--active');

        panels.forEach(function(p) {
          p.classList.remove('pg-panel--active');
        });

        var target = document.querySelector('[data-pg-panel="' + idx + '"][data-pg-section="' + sectionId + '"]');
        if (target) target.classList.add('pg-panel--active');
      });
    });
  })();
</script>

{% schema %}
