{% comment %}
  sections/custom-faq.liquid

  Uses a PRODUCT metafield:
  - "FAQ Items" (List of metaobjects)
  - Metaobject type: "FAQ Item"
  - Fields (handles): question, answer, image

  IMPORTANT:
  - Update the namespace/key below if yours differs.
    Default assumed: product.metafields.custom.faq_items
{% endcomment %}

{%- assign faq_items = product.metafields.custom.faq_items.value -%}

<div
  id="custom-faq-{{ section.id }}"
  class="cfq shopify-section section-wrapper section-custom-faq"
  style="
    --cfq-max-width: {{ section.settings.max_width }}px;
    --cfq-padding-top: {{ section.settings.section_padding_top }}px;
    --cfq-padding-bottom: {{ section.settings.section_padding_bottom }}px;
    --cfq-duration: {{ section.settings.duration }}ms;
    --cfq-heading-font-size-desktop: {{ section.settings.heading_font_size_desktop }}px;
    --cfq-heading-font-size-mobile: {{ section.settings.heading_font_size_mobile }}px;
    --cfq-heading-margin-bottom: {{ section.settings.heading_margin_bottom }}px;
  "
>
  <div class="cfq__inner section section--page-width">
    {% if section.settings.heading != blank %}
      <h2 class="cfq__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if faq_items != blank and faq_items.size > 0 %}
      <div class="cfq__list" data-cfq-root>
        {% for item in faq_items %}
          {%- assign q = item.question.value | default: item.question -%}
          {%- assign img = item.image.value | default: item.image -%}

          {% if q != blank or item.answer != blank or img != blank %}
            <details
              class="cfq__item"
              {% if section.settings.open_first and forloop.first %}open{% endif %}
              data-cfq-details
            >
              <summary class="cfq__summary" data-cfq-summary>
                <span class="cfq__question">{{ q }}</span>
                <span class="cfq__icon" aria-hidden="true">+</span>
              </summary>

              <div class="cfq__content" data-cfq-content>
                <div class="cfq__content-inner" data-cfq-inner>
                  {% if item.answer != blank %}
                    <div class="cfq__answer">{{ item.answer | metafield_tag }}</div>
                  {% endif %}

                  {% if img != blank %}
                    <div class="cfq__image">
                      {{
                        img
                        | image_url: width: 2000
                        | image_tag: loading: 'lazy'
                      }}
                    </div>
                  {% endif %}
                </div>
              </div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% if faq_items != blank and faq_items.size > 0 %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for item in faq_items -%}
          {%- assign q = item.question.value | default: item.question -%}
          {%- if q != blank and item.answer != blank -%}
            {%- unless forloop.first -%},{%- endunless -%}
            {
              "@type": "Question",
              "name": {{ q | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ item.answer | metafield_tag | strip_html | strip | json }}
              }
            }
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>
{% endif %}

{% style %}
  .cfq {
    width: 100%;
    padding-top: var(--cfq-padding-top, 24px);
    padding-bottom: var(--cfq-padding-bottom, 24px);
  }

  .cfq__inner {
    max-width: var(--cfq-max-width, 1024px);
    margin: 0 auto;
  }

  .cfq__heading {
    text-align: center;
    font-weight: 700;
    font-size: var(--cfq-heading-font-size-desktop, 32px);
    line-height: 1.15;
    margin-bottom: var(--cfq-heading-margin-bottom, 30px);
  }

  .cfq__item {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  .cfq__item:last-child {
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .cfq__summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 15px 0;
    user-select: none;
  }
  .cfq__summary::-webkit-details-marker { display: none; }

  .cfq__question {
    font-size: 18px;
    line-height: 1.25;
    font-weight: 400;
  }

  .cfq__icon {
    font-size: 26px;
    line-height: 1;
    font-weight: 300;
    transition: transform var(--cfq-duration) cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
  }

  .cfq__item[open] .cfq__icon,
  .cfq__item.is-opening .cfq__icon { transform: rotate(45deg); }

  .cfq__item.is-closing .cfq__icon { transform: rotate(0deg); }

  .cfq__content {
    overflow: hidden;
    height: 0;
    display: block;
  }

  .cfq__content-inner {
    padding: 0 0 18px 0;
    display: grid;
    gap: 14px;
  }

  .cfq__answer {
    font-size: 16px;
    line-height: 1.6;
  }
  .cfq__answer p {
    margin: 0 0 12px 0;
    font-size: inherit;
    line-height: inherit;
  }

  .cfq__image img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .cfq__heading {
      font-size: var(--cfq-heading-font-size-mobile, 24px);
    }
  }
{% endstyle %}

<script>
  (function () {
    const root = document.getElementById("custom-faq-{{ section.id }}");
    if (!root) return;

    const duration = {{ section.settings.duration | json }};
    const easing = "cubic-bezier(0.2, 0.8, 0.2, 1)";
    root.style.setProperty("--cfq-duration", duration + "ms");

    const detailsEls = Array.from(root.querySelectorAll("[data-cfq-details]"));

    function setClosed(details) {
      const content = details.querySelector("[data-cfq-content]");
      if (!content) return;
      content.style.height = "0px";
    }

    function setOpen(details) {
      const content = details.querySelector("[data-cfq-content]");
      const inner = details.querySelector("[data-cfq-inner]");
      if (!content || !inner) return;
      content.style.height = inner.scrollHeight + "px";
    }

    function animateOpen(details) {
      const content = details.querySelector("[data-cfq-content]");
      const inner = details.querySelector("[data-cfq-inner]");
      if (!content || !inner) return;

      details.classList.remove("is-closing");
      details.classList.add("is-opening");

      details.open = true;

      content.style.height = "0px";
      const end = inner.scrollHeight;

      if (content.__cfqAnim) content.__cfqAnim.cancel();

      const anim = content.animate(
        [{ height: "0px" }, { height: end + "px" }],
        { duration, easing }
      );

      content.__cfqAnim = anim;

      anim.onfinish = () => {
        content.style.height = end + "px";
        details.classList.remove("is-opening");
        content.__cfqAnim = null;
      };

      anim.oncancel = () => { content.__cfqAnim = null; };
    }

    function animateClose(details) {
      const content = details.querySelector("[data-cfq-content]");
      const inner = details.querySelector("[data-cfq-inner]");
      if (!content || !inner) return;

      details.classList.remove("is-opening");
      details.classList.add("is-closing");

      const start = inner.scrollHeight;
      content.style.height = start + "px";

      if (content.__cfqAnim) content.__cfqAnim.cancel();

      const anim = content.animate(
        [{ height: start + "px" }, { height: "0px" }],
        { duration, easing }
      );

      content.__cfqAnim = anim;

      anim.onfinish = () => {
        details.open = false;
        content.style.height = "0px";
        details.classList.remove("is-closing");
        content.__cfqAnim = null;
      };

      anim.oncancel = () => { content.__cfqAnim = null; };
    }

    detailsEls.forEach((details) => {
      const summary = details.querySelector("[data-cfq-summary]");
      const content = details.querySelector("[data-cfq-content]");
      const inner = details.querySelector("[data-cfq-inner]");
      if (!summary || !content || !inner) return;

      if (details.open) setOpen(details);
      else setClosed(details);

      summary.addEventListener("click", (e) => {
        e.preventDefault();
        if (details.open) animateClose(details);
        else animateOpen(details);
      });
    });

    const syncOpenHeights = () => {
      detailsEls.forEach((d) => {
        if (d.open) setOpen(d);
      });
    };

    window.addEventListener("resize", syncOpenHeights);

    root.querySelectorAll("img").forEach((img) => {
      if (img.complete) return;
      img.addEventListener("load", syncOpenHeights, { once: true });
    });
  })();
</script>

{% schema %}
{
  "name": "Custom FAQ",
  "tag": "div",
  "class": "section-wrapper",
  "settings": [
    {
        "type": "header",
        "content": "Section"
    },
    {
        "type": "range",
        "id": "max_width",
        "label": "Max width (px)",
        "min": 320,
        "max": 1408,
        "step": 64,
        "default": 1024
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 90,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 90,
      "step": 1,
      "default": 24
    },
    {
        "type": "header",
        "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "label": "Heading font size desktop",
      "min": 10,
      "max": 90,
      "step": 1,
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size mobile",
      "min": 10,
      "max": 90,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Heading margin bottom",
      "min": 10,
      "max": 90,
      "step": 1,
      "default": 30
    },
    {
        "type": "header",
        "content": "Accordions"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first item by default",
      "default": false
    },
    {
      "type": "range",
      "id": "duration",
      "label": "Animation duration",
      "min": 180,
      "max": 700,
      "step": 10,
      "unit": "ms",
      "default": 360
    }
  ],
  "presets": [
    { "name": "Custom FAQ" }
  ]
}
{% endschema %}
