{% comment %}
  Section: Custom footer (single-file)
  - Breakpoint: 830px
  - Centered on mobile
  - Desktop: wider left area for logo/social
  - Menu columns are blocks (heading + menu picker)
{% endcomment %}

<section
  class="custom-footer shopify-section section-wrapper"
  style="
    --cf-bg: {{ section.settings.background_color }};
    --cf-text: {{ section.settings.text_color }};
    --cf-muted: {{ section.settings.muted_text_color }};
    --cf-pt: {{ section.settings.padding_top }}px;
    --cf-pb: {{ section.settings.padding_bottom }}px;
    --cf-left-width: {{ section.settings.left_area_width_desktop }}%;
    --cf-logo-desktop: {{ section.settings.logo_width_desktop }}px;
    --cf-logo-mobile: {{ section.settings.logo_width_mobile }}px;
  "
>
  <div class="custom-footer__inner section section--page-width">
    <div class="custom-footer__grid">
      <!-- Left: logo + socials -->
      <div class="custom-footer__left">
        {% if section.settings.footer_image != blank %}
          <a class="custom-footer__brand" href="{{ routes.root_url }}">
            {{
              section.settings.footer_image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                class: 'custom-footer__logo',
                alt: section.settings.footer_image.alt | default: shop.name
            }}
          </a>
        {% else %}
          <a class="custom-footer__brand custom-footer__brand--text" href="{{ routes.root_url }}">
            {{ shop.name }}
          </a>
        {% endif %}

        {% if section.settings.show_socials %}
            <h3 class="custom-footer__social-heading">{{ section.settings.social_heading }}</h3>
          <div class="custom-footer__social" aria-label="Social links">
            {% assign has_social = false %}

            {% if section.settings.instagram_social != blank %}
              {% assign has_social = true %}
              <a class="custom-footer__social-link" href="{{ section.settings.instagram_social }}" target="_blank" rel="noopener" aria-label="Instagram">
                {{- 'icon-instagram.svg' | inline_asset_content -}}
              </a>
            {% endif %}

            {% if section.settings.pinterest_social != blank %}
                <a class="custom-footer__social-link" href="{{ section.settings.pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">
                    {{- 'icon-pinterest.svg' | inline_asset_content -}}
                 </a>
            {% endif %}

            {% if section.settings.facebook_social != blank %}
              {% assign has_social = true %}
              <a class="custom-footer__social-link" href="{{ section.settings.facebook_social }}" target="_blank" rel="noopener" aria-label="Facebook">
                {{- 'icon-facebook.svg' | inline_asset_content -}}
              </a>
            {% endif %}

            {% if section.settings.tiktok_social != blank %}
              {% assign has_social = true %}
              <a class="custom-footer__social-link" href="{{ section.settings.tiktok_social }}" target="_blank" rel="noopener" aria-label="TikTok">
                {{- 'icon-tiktok.svg' | inline_asset_content }}
              </a>
            {% endif %}

            {% if has_social == false %}
              <p class="custom-footer__note">
                Add social links in Theme settings → Social media.
              </p>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <!-- Right: menu columns -->
      <div class="custom-footer__right">
        <div class="custom-footer__columns">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'menu_column' %}
                {% assign menu = block.settings.menu %}
                <nav class="custom-footer__col" {{ block.shopify_attributes }} aria-label="{{ block.settings.heading | escape }}">
                  {% if block.settings.heading != blank %}
                    <h3 class="custom-footer__heading">{{ block.settings.heading }}</h3>
                  {% elsif menu != blank %}
                    <h3 class="custom-footer__heading">{{ menu.title }}</h3>
                  {% endif %}

                  {% if menu != blank and menu.links.size > 0 %}
                    <ul class="custom-footer__links">
                      {% for link in menu.links %}
                        <li class="custom-footer__link-item">
                          <a class="custom-footer__link" href="{{ link.url }}">{{ link.title }}</a>
                        </li>
                      {% endfor %}
                    </ul>
                  {% else %}
                    <p class="custom-footer__note">Select a menu for this column.</p>
                  {% endif %}
                </nav>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div>
    <div class="custom-footer__payment-methods"
      style="
        --pm-pt: {{ section.settings.payment_methods_padding_top }}px;
        --pm-pb: {{ section.settings.payment_methods_padding_bottom }}px;
      ">
      {% render 'payment-methods' %}
    </div>
  </div>
</section>

{% style %}
  .custom-footer {
    background: var(--cf-bg);
    color: var(--cf-text);
    padding-top: var(--cf-pt);
    padding-bottom: var(--cf-pb);
  }

  .custom-footer__grid {
    display: grid;
    gap: 50px;
    align-items: start;
  }

  /* MOBILE: everything centered */
  .custom-footer__left,
  .custom-footer__right,
  .custom-footer__col,
  .custom-footer__links,
  .custom-footer__note {
    text-align: center;
  }

  .custom-footer__brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    padding-bottom:30px;
  }

  .custom-footer__brand--text {
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .custom-footer__logo {
    width: var(--cf-logo-mobile);
    max-width: 100%;
    height: auto;
    display: block;
  }

  .custom-footer__social {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .custom-footer__social-link {
    display: inline-flex;
    width: 34px;
    height: 34px;
    align-items: center;
    justify-content: center;
    color: var(--cf-text);
    opacity: 0.9;
    transition: opacity 160ms ease;
  }

  .custom-footer__social-link:hover {
    opacity: 1;
  }

  .custom-footer__social-link svg {
    width: 22px;
    height: 22px;
    display: block;
  }

  .custom-footer__columns {
    display: grid;
    gap: 50px;
  }

  .custom-footer__social-heading {
    margin:0 0 12px 0;
    font-size: 18px;
    letter-spacing: .75px;
    font-weight:700;
  }

  .custom-footer__heading {
    margin-bottom:16px;
    font-size: 14px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .custom-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .custom-footer__link {
    color: var(--cf-text);
    text-decoration: none;
    opacity: 0.9;
    transition: opacity 160ms ease;
  }

  .custom-footer__link:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .custom-footer__note {
    margin: 0;
    color: var(--cf-muted);
    font-size: 13px;
  }

  /* DESKTOP: two areas, with left wider */
  @media (min-width: 830px) {
    .custom-footer__grid {
      grid-template-columns: var(--cf-left-width) 1fr;
      gap: 40px;
    }

    .custom-footer__left {
      text-align: left;
    }

    .custom-footer__social {
      justify-content: flex-start;
    }

    .custom-footer__logo {
      width: var(--cf-logo-desktop);
    }

    .custom-footer__columns {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 26px;
      align-items: start;
    }

    .custom-footer__col,
    .custom-footer__links,
    .custom-footer__note {
      text-align: left;
    }
  }

  .custom-footer__payment-methods {
    padding-top: var(--pm-pt);
    padding-bottom: var(--pm-pb);
  }
{% endstyle %}

{% schema %}
{
  "name": "Custom footer",
  "tag": "section",
  "class": "section-custom-footer",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "footer_image",
      "label": "Footer logo/image"
    },
    {
      "type": "range",
      "id": "left_area_width_desktop",
      "label": "Left area width (desktop %)",
      "min": 25,
      "max": 55,
      "step": 1,
      "default": 38
    },
    {
      "type": "range",
      "id": "logo_width_desktop",
      "label": "Logo width (desktop ≥ 830px)",
      "min": 120,
      "max": 520,
      "step": 10,
      "default": 280
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Logo width (mobile < 830px)",
      "min": 100,
      "max": 360,
      "step": 10,
      "default": 200
    },
    
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_socials",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Social heading",
      "default": "Get social with Elivide."
    },
    {
        "type": "url",
        "id": "facebook_social",
        "label": "Facebook URL",
        "visible_if": "{{ section.settings.show_socials == true }}"
    },
    {
        "type": "url",
        "id": "instagram_social",
        "label": "Instagram URL",
        "visible_if": "{{ section.settings.show_socials == true }}"
    },
    {
        "type": "url",
        "id": "pinterest_social",
        "label": "Pinterest URL",
        "visible_if": "{{ section.settings.show_socials == true }}"
    },
    {
        "type": "url",
        "id": "tiktok_social",
        "label": "Tik Tok URL",
        "visible_if": "{{ section.settings.show_socials == true }}"
    },
    {
      "type": "header",
      "content": "Payment Methods"
    },
    {
      "type": "range",
      "id": "payment_methods_padding_top",
      "label": "Payment methods padding top",
      "min": 0,
      "max": 99,
      "step": 1,
      "default": 50
    },
    {
      "type": "range",
      "id": "payment_methods_padding_bottom",
      "label": "Payment methods padding bottom",
      "min": 0,
      "max": 99,
      "step": 1,
      "default": 30
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0d1b26"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#b9c3cc"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64
    }
    
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom footer",
      "blocks": [
        { "type": "menu_column" },
        { "type": "menu_column" },
        { "type": "menu_column" }
      ]
    }
  ]
}
{% endschema %}
