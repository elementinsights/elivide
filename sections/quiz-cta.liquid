{% comment %}
  Quiz CTA — contained card with image + CTA side by side.
  Sits on a neutral background to flow with surrounding sections.
{% endcomment %}

<section class="qz" style="--qz-section-bg: {{ section.settings.section_bg }};">
  <div class="qz__card"
    style="
      --qz-card-bg: {{ section.settings.card_bg }};
      --qz-accent: {{ section.settings.accent_color }};
      --qz-heading: {{ section.settings.heading_color }};
      --qz-em: {{ section.settings.emphasis_color }};
      --qz-sub: {{ section.settings.subtext_color }};
      --qz-btn-bg: {{ section.settings.button1_bg }};
      --qz-btn-text: {{ section.settings.button1_text }};
      --qz-trust: {{ section.settings.trust_color }};
      --qz-kicker: {{ section.settings.kicker_color }};
    "
  >
    {%- comment -%} Image side {%- endcomment -%}
    <div class="qz__image-wrap">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          srcset="
            {{ section.settings.image | image_url: width: 450 }} 450w,
            {{ section.settings.image | image_url: width: 680 }} 680w,
            {{ section.settings.image | image_url: width: 900 }} 900w
          "
          sizes="(max-width: 768px) 100vw, 45vw"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
          class="qz__image"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      {% else %}
        <div class="qz__image-placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'qz__placeholder-svg' }}
        </div>
      {% endif %}
    </div>

    {%- comment -%} Content side {%- endcomment -%}
    <div class="qz__content">
      {% if section.settings.kicker != blank %}
        <div class="qz__kicker">
          <span class="qz__kicker-dot" aria-hidden="true"></span>
          <span>{{ section.settings.kicker }}</span>
        </div>
      {% endif %}

      <h2 class="qz__heading">{{ section.settings.heading }}</h2>

      {% if section.settings.subheading != blank %}
        <p class="qz__sub">{{ section.settings.subheading }}</p>
      {% endif %}

      <div class="qz__actions">
        {% if section.settings.button1_label != blank %}
          <a href="{{ section.settings.button1_link }}" class="qz__btn-primary">
            <span class="qz__btn-shimmer" aria-hidden="true"></span>
            <span class="qz__btn-label">{{ section.settings.button1_label }}</span>
            <svg class="qz__btn-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        {% endif %}
        {% if section.settings.button2_label != blank %}
          <a href="{{ section.settings.button2_link }}" class="qz__btn-secondary">
            {{ section.settings.button2_label }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        {% endif %}
      </div>

      {% if section.settings.trust_1 != blank or section.settings.trust_2 != blank or section.settings.trust_3 != blank %}
        <div class="qz__trust">
          {% if section.settings.trust_1 != blank %}
            <div class="qz__trust-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15l-5-5 1.41-1.41L11 14.17l7.59-7.59L20 8l-9 9z" fill="currentColor"/></svg>
              <span>{{ section.settings.trust_1 }}</span>
            </div>
          {% endif %}
          {% if section.settings.trust_2 != blank %}
            <div class="qz__trust-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15l-5-5 1.41-1.41L11 14.17l7.59-7.59L20 8l-9 9z" fill="currentColor"/></svg>
              <span>{{ section.settings.trust_2 }}</span>
            </div>
          {% endif %}
          {% if section.settings.trust_3 != blank %}
            <div class="qz__trust-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15l-5-5 1.41-1.41L11 14.17l7.59-7.59L20 8l-9 9z" fill="currentColor"/></svg>
              <span>{{ section.settings.trust_3 }}</span>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% style %}
  /* ── Section wrapper ── */
  .qz {
    padding: 60px 24px;
    background: var(--qz-section-bg);
  }

  /* ── Card ── */
  .qz__card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 1100px;
    margin: 0 auto;
    background: var(--qz-card-bg);
    border-radius: 20px;
    overflow: hidden;
    min-height: 480px;
  }

  /* ── Image ── */
  .qz__image-wrap {
    position: relative;
    overflow: hidden;
  }

  .qz__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .qz__image-placeholder {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .qz__placeholder-svg {
    width: 60%;
    opacity: 0.2;
  }

  /* ── Content ── */
  .qz__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 56px 48px;
  }

  /* ── Kicker ── */
  .qz__kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--qz-kicker);
    margin-bottom: 20px;
  }

  .qz__kicker-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--qz-kicker);
    flex-shrink: 0;
  }

  /* ── Heading ── */
  .qz__heading {
    font-family: var(--font-subheading--family, var(--font-heading--family, serif));
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700;
    color: var(--qz-heading);
    margin: 0 0 14px;
    letter-spacing: -0.3px;
    line-height: 1.18;
    text-wrap: balance;
  }

  .qz__heading em,
  .qz__heading i {
    font-style: italic;
    color: var(--qz-em);
    font-weight: 400;
  }

  /* ── Subheading ── */
  .qz__sub {
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.98rem;
    color: var(--qz-sub);
    max-width: 380px;
    margin: 0 0 32px;
    line-height: 1.65;
  }

  /* ── Actions ── */
  .qz__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  /* Primary CTA */
  .qz__btn-primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 36px;
    background: var(--qz-btn-bg);
    color: var(--qz-btn-text);
    border: none;
    border-radius: 100px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: 0 4px 20px rgba(45, 90, 61, 0.25);
  }

  .qz__btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 28px rgba(45, 90, 61, 0.4);
  }

  .qz__btn-label {
    position: relative;
    z-index: 1;
  }

  .qz__btn-arrow {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .qz__btn-primary:hover .qz__btn-arrow {
    transform: translateX(4px);
  }

  .qz__btn-shimmer {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.18) 50%,
      transparent 70%
    );
    animation: qzShimmer 3.5s ease-in-out infinite;
    z-index: 0;
    pointer-events: none;
  }

  @keyframes qzShimmer {
    0%   { left: -100%; }
    40%  { left: 100%; }
    100% { left: 100%; }
  }

  /* Secondary link */
  .qz__btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--qz-sub);
    text-decoration: none;
    transition: color 0.25s ease, gap 0.25s ease;
  }

  .qz__btn-secondary:hover {
    color: #ffffff;
    gap: 10px;
  }

  /* ── Trust row ── */
  .qz__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 20px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .qz__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.75rem;
    color: var(--qz-trust);
    letter-spacing: 0.2px;
    white-space: nowrap;
  }

  .qz__trust-item svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .qz {
      padding: 40px 16px;
    }

    .qz__card {
      grid-template-columns: 1fr;
      border-radius: 16px;
      min-height: auto;
    }

    .qz__image-wrap {
      aspect-ratio: 1 / 1;
    }

    .qz__content {
      padding: 36px 28px 40px;
    }

    .qz__kicker {
      margin-bottom: 16px;
    }

    .qz__sub {
      margin-bottom: 28px;
    }

    .qz__actions {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 28px;
    }

    .qz__btn-primary {
      width: 100%;
      justify-content: center;
    }

    .qz__btn-secondary {
      align-self: center;
    }

    .qz__trust {
      flex-direction: column;
      gap: 8px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Quiz CTA",
  "tag": "div",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker text (above heading)",
      "default": "PERSONALIZED FOR YOU"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading (use italic for emphasis)",
      "default": "<p>Not sure where to <em>start</em>?</p>"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Take our 60-second quiz and discover the perfect supplement routine for your goals."
    },
    {
      "type": "text",
      "id": "button1_label",
      "label": "Primary button label",
      "default": "Take the Quiz"
    },
    {
      "type": "url",
      "id": "button1_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Secondary link label",
      "default": "Shop All Products"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Secondary link"
    },
    {
      "type": "header",
      "content": "Trust indicators"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "Free & takes 60 seconds"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2",
      "default": "Personalized results"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust item 3",
      "default": "10,000+ quizzes completed"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background (match page)",
      "default": "#fff7ef"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#1a1f2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#679992"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "emphasis_color",
      "label": "Italic emphasis color",
      "default": "#8CC5A2"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subheading color",
      "default": "#ffffffa0"
    },
    {
      "type": "color",
      "id": "kicker_color",
      "label": "Kicker text color",
      "default": "#8CC5A2"
    },
    {
      "type": "color",
      "id": "button1_bg",
      "label": "Primary button background",
      "default": "#2D5A3D"
    },
    {
      "type": "color",
      "id": "button1_text",
      "label": "Primary button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "trust_color",
      "label": "Trust indicators color",
      "default": "#ffffff70"
    }
  ],
  "presets": [
    {
      "name": "Quiz CTA"
    }
  ]
}
{% endschema %}
