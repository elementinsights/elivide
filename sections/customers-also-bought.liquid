
<script
  src="{{ 'product-recommendations.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

<product-recommendations
  id="cab-{{ section.id }}"
  class="cab-wrapper"
  data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.max_products }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-intent="complementary"
  data-recommendations-performed="{{ recommendations.performed }}"
  {{ section.shopify_attributes }}
>
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div class="cab-section section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
    style="--cab-pad-top: {{ section.settings.padding_top }}px; --cab-pad-bottom: {{ section.settings.padding_bottom }}px;"
  >
    {%- if recommendations.performed and recommendations.products_count > 0 -%}
      {%- assign rec_products = recommendations.products -%}
    {%- elsif recommendations.performed and recommendations.products_count == 0 -%}
      {%- assign rec_products = collections.all.products | reject: 'id', product.id -%}
    {%- else -%}
      {%- assign rec_products = null -%}
    {%- endif -%}

    {%- if rec_products != null and rec_products.size > 0 or recommendations.performed == false -%}

      <div class="cab-header">
        <h3 class="cab-title">{{ section.settings.heading }}</h3>
        {%- if section.settings.subheading != blank -%}
          <p class="cab-subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      {%- if rec_products != null and rec_products.size > 0 -%}
        <div class="cab-grid" data-cab-section="{{ section.id }}">
          {%- comment -%} Current product {%- endcomment -%}
          <div class="cab-card">
            <a href="{{ product.url }}" class="cab-card__img">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 749px) 40vw, 28vw"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              {%- endif -%}
              <span class="cab-card__tag">This item</span>
            </a>
            <div class="cab-card__info">
              <div class="cab-card__stars">{% render 'star-wrapper' %}</div>
              <a href="{{ product.url }}" class="cab-card__name">{{ product.title }}</a>
              <span class="cab-card__price">{{ current_variant.price | money }}</span>
            </div>
            <div class="cab-card__action" data-cab-main-action>
              {%- if current_variant.available -%}
                <product-form-component
                  data-section-id="{{ section.id }}"
                  data-product-id="{{ product.id }}"
                  on:submit="/handleSubmit"
                  data-cab-main-form
                >
                  <div class="visually-hidden" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
                  {%- form 'product', product, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                    <input type="hidden" name="id" ref="variantId" value="{{ current_variant.id }}">
                    {% render 'add-to-cart-button',
                      can_add_to_cart: true,
                      class: 'add-to-cart-button cab-card__btn',
                      product: product
                    %}
                  {%- endform -%}
                </product-form-component>
                <span class="cab-card__in-cart" style="display:none;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  In Cart
                </span>
              {%- endif -%}
            </div>
          </div>

          {%- assign rec_index = 0 -%}
          {%- for p in rec_products limit: section.settings.max_products -%}
            {%- assign v = p.selected_or_first_available_variant -%}
            {%- if v.available -%}
              {%- assign rec_index = rec_index | plus: 1 -%}
              <span class="cab-sep cab-rec cab-rec--{{ rec_index }}" aria-hidden="true">+</span>

              <div class="cab-card cab-rec cab-rec--{{ rec_index }}">
                <a href="{{ p.url }}" class="cab-card__img">
                  {%- if p.featured_image -%}
                    <img
                      src="{{ p.featured_image | image_url: width: 600 }}"
                      srcset="{{ p.featured_image | image_url: width: 400 }} 400w, {{ p.featured_image | image_url: width: 600 }} 600w, {{ p.featured_image | image_url: width: 800 }} 800w"
                      sizes="(max-width: 749px) 40vw, 28vw"
                      alt="{{ p.featured_image.alt | escape }}"
                      loading="lazy"
                      width="{{ p.featured_image.width }}"
                      height="{{ p.featured_image.height }}"
                    >
                  {%- endif -%}
                  {%- if p.compare_at_price > p.price -%}
                    {%- assign save_pct = p.compare_at_price | minus: p.price | times: 100 | divided_by: p.compare_at_price -%}
                    <span class="cab-card__tag cab-card__tag--sale">Save {{ save_pct }}%</span>
                  {%- endif -%}
                </a>
                <div class="cab-card__info">
                  <div class="cab-card__stars">{% render 'star-wrapper' %}</div>
                  <a href="{{ p.url }}" class="cab-card__name">{{ p.title }}</a>
                  <div class="cab-card__price-row">
                    <span class="cab-card__price">{{ v.price | money }}</span>
                    {%- if p.compare_at_price > p.price -%}
                      <s class="cab-card__compare">{{ p.compare_at_price | money }}</s>
                    {%- endif -%}
                  </div>
                </div>
                <div class="cab-card__action">
                  {%- if v.available -%}
                    <product-form-component
                      data-section-id="{{ section.id }}"
                      data-product-id="{{ p.id }}"
                      on:submit="/handleSubmit"
                    >
                      <div class="visually-hidden" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
                      {%- form 'product', p, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                        <input type="hidden" name="id" ref="variantId" value="{{ v.id }}">
                        {% render 'add-to-cart-button',
                          can_add_to_cart: true,
                          class: 'add-to-cart-button cab-card__btn',
                          product: p
                        %}
                      {%- endform -%}
                    </product-form-component>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="cab-grid cab-grid--skeleton">
          {%- for i in (1..3) -%}
            {%- unless forloop.first -%}<span class="cab-sep">+</span>{%- endunless -%}
            <div class="cab-card"><div class="cab-card__img cab-skel-pulse"></div></div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</product-recommendations>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var mainVariantId = '{{ current_variant.id }}';

    function swapToInCart() {
      var action = document.querySelector('#cab-' + sectionId + ' [data-cab-main-action]');
      if (!action) return;
      var form = action.querySelector('[data-cab-main-form]');
      var label = action.querySelector('.cab-card__in-cart');
      if (form) form.style.display = 'none';
      if (label) label.style.display = '';
    }

    function swapToAddToCart() {
      var action = document.querySelector('#cab-' + sectionId + ' [data-cab-main-action]');
      if (!action) return;
      var form = action.querySelector('[data-cab-main-form]');
      var label = action.querySelector('.cab-card__in-cart');
      if (form) form.style.display = '';
      if (label) label.style.display = 'none';
    }

    function checkCart() {
      fetch('/cart.js')
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          var inCart = cart.items.some(function(item) {
            return String(item.variant_id) === mainVariantId;
          });
          if (inCart) {
            swapToInCart();
          } else {
            swapToAddToCart();
          }
        });
    }

    // Listen for theme's cart add event
    document.addEventListener('cart:update', function() {
      setTimeout(checkCart, 300);
    });

    // Watch for recommendations to load (async) and check cart state + attach submit listener
    var recEl = document.getElementById('cab-' + sectionId);
    if (recEl) {
      new MutationObserver(function(mutations, observer) {
        var mainAction = recEl.querySelector('[data-cab-main-action]');
        if (mainAction) {
          // Recommendations have loaded — check cart state immediately
          checkCart();
          var mainForm = recEl.querySelector('[data-cab-main-form]');
          if (mainForm) {
            mainForm.addEventListener('submit', function() {
              setTimeout(checkCart, 1500);
            });
          }
          observer.disconnect();
        }
      }).observe(recEl, { childList: true, subtree: true });
    }
  })();
</script>

{% stylesheet %}
  .cab-wrapper {
    display: block;
  }

  .cab-wrapper.hidden {
    display: none;
  }

  .cab-section {
    padding-top: var(--cab-pad-top, 48px);
    padding-bottom: var(--cab-pad-bottom, 48px);
    color: #000000;
  }

  .cab-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .cab-title {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .cab-subtitle {
    margin: 8px 0 0;
    font-size: 0.95rem;
    opacity: 0.45;
    line-height: 1.5;
  }

  /* Grid — products fill available width */
  .cab-grid {
    display: flex;
    align-items: stretch;
    gap: 6px;
    width: 100%;
    container-type: inline-size;
  }

  /* Product cards — equal flex */
  .cab-card {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .cab-card__img {
    display: block;
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 12px;
    background: #f7f6f3;
  }

  .cab-card__img img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .cab-card__img:hover img {
    transform: scale(1.04);
  }

  .cab-card__tag {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 7px 14px;
    background: #2a7d6f;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: 6px;
    line-height: 1;
  }

  .cab-card__tag--sale {
    background: #c0392b;
  }

  .cab-card__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 4px 0;
    flex: 1;
  }

  .cab-card__stars {
    display: flex;
    align-items: center;
    gap: 2px;
    margin-bottom: 4px;
  }

  .cab-card__stars svg {
    width: 14px;
    height: 14px;
  }

  .cab-card__name {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
    color: #000000;
    text-decoration: none;
    display: block;
  }

  .cab-card__name:hover {
    text-decoration: none;
  }

  .cab-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .cab-card__price {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .cab-card__compare {
    font-size: 0.75rem;
    opacity: 0.4;
  }

  /* Action area — pushed to bottom */
  .cab-card__action {
    margin-top: auto;
    padding: 16px 4px 0;
  }

  .cab-card__btn {
    position: relative;
    overflow: hidden;
    width: fit-content;
    padding: 14px 24px;
    border: 1px solid #000;
    background: #000;
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
    cursor: pointer;
    border-radius: 8px;
    transition: opacity 0.2s ease;
    font-family: inherit;
    line-height: 1.4;
    white-space: nowrap;
    box-sizing: border-box;
  }

  /* Override buy-buttons.liquid styles that come with .add-to-cart-button class */
  .cab-card__btn.add-to-cart-button {
    padding: 14px 24px;
    text-transform: uppercase;
  }

  .cab-card__btn .add-to-cart-icon svg {
    width: 18px;
    height: 18px;
  }

  .cab-card__in-cart {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 1.1rem;
    font-weight: 700;
    color: #2a7d6f;
    letter-spacing: 0.02em;
  }

  .cab-card__in-cart svg {
    flex-shrink: 0;
  }

  .cab-card__btn[data-added='true'] {
    background: #2a7d6f;
    border-color: #2a7d6f;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .cab-card__btn:hover {
    opacity: 0.85;
  }

  .cab-card__btn:disabled {
    opacity: 0.5;
    cursor: wait;
  }

  /* Separator — centered vertically on the image */
  .cab-sep {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    align-self: flex-start;
    width: 64px;
    /* Image is aspect-ratio: 1, so height = card width.
       Card width ≈ (container - 2×64px seps - 4×6px gaps) / 3 cards */
    height: calc((100cqi - 152px) / 3);
    font-size: 2.2rem;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.3);
  }

  /* Skeleton */
  .cab-grid--skeleton .cab-card__img {
    background: #eee;
  }

  .cab-skel-pulse {
    animation: cab-pulse 1.5s ease-in-out infinite;
  }

  @keyframes cab-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Tablet */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .cab-sep {
      width: 44px;
      font-size: 1.6rem;
      /* Tablet: 3 cards + 2×44px seps + 4×6px gaps */
      height: calc((100cqi - 112px) / 3);
    }

    .cab-card__name {
      font-size: 0.88rem;
    }
  }

  /* Mobile side-by-side (501px–749px) */
  @media screen and (min-width: 501px) and (max-width: 749px) {
    .cab-title {
      font-size: 1.4rem;
    }

    .cab-header {
      margin-bottom: 24px;
    }

    .cab-sep {
      width: 36px;
      font-size: 1.3rem;
      height: calc((100cqi - 48px) / 2);
    }

    .cab-card__img {
      border-radius: 10px;
    }

    .cab-card__name {
      font-size: 0.95rem;
    }

    .cab-card__price {
      font-size: 0.98rem;
    }

    .cab-card__stars svg {
      width: 12px;
      height: 12px;
    }

    .cab-card__info {
      padding: 8px 2px 0;
    }

    .cab-card__tag {
      font-size: 0.7rem;
      padding: 6px 12px;
    }

    .cab-card__btn {
      padding: 10px 16px;
      font-size: 0.75rem;
    }

    .cab-card__action {
      padding: 8px 2px 0;
    }

    .cab-rec.cab-rec--2,
    .cab-rec.cab-rec--3 {
      display: none;
    }
  }

  /* Mobile stacked (500px and below) */
  @media screen and (max-width: 500px) {
    .cab-title {
      font-size: 1.4rem;
    }

    .cab-header {
      margin-bottom: 24px;
    }

    .cab-card__img {
      border-radius: 10px;
    }

    .cab-card__name {
      font-size: 0.85rem;
    }

    .cab-card__price {
      font-size: 0.88rem;
    }

    .cab-card__info {
      padding: 8px 2px 0;
    }

    .cab-card__action {
      padding: 10px 2px 0;
    }

    .cab-card__tag {
      font-size: 0.6rem;
      padding: 5px 9px;
    }

    .cab-card__btn {
      padding: 3px 12px;
      font-size: 0.62rem;
      width: fit-content;
      height: inherit;
    }

    .cab-card__btn .add-to-cart-icon {
      position: relative;
      top: -1px;
    }

    .cab-card__btn .add-to-cart-text__content {
      font-size: 0;
    }

    .cab-card__btn .add-to-cart-text__content::after {
      content: 'Add';
      font-size: 0.62rem;
    }

    .cab-card__in-cart {
      font-size: 0.75rem;
      gap: 5px;
    }

    .cab-card__in-cart svg {
      width: 14px;
      height: 14px;
    }

    .cab-card__stars svg {
      width: 11px;
      height: 11px;
    }

    .cab-sep {
      width: 28px;
      font-size: 1.2rem;
      height: calc((100cqi - 40px) / 2);
    }

    .cab-rec.cab-rec--2,
    .cab-rec.cab-rec--3 {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Also Bought",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete Your Routine"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Frequently purchased together"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Also Bought"
    }
  ]
}
{% endschema %}
