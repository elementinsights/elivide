{% assign t = type | default: 'blank' %}

{% if t == 'check' %}
  <span class="compare__icon" aria-label="Yes">
    <svg viewBox="0 0 64 64" width="44" height="44" role="img" aria-hidden="true">
      <circle cx="32" cy="32" r="22" fill="{{ icon_color }}"></circle>
      <path
        d="M26 33.5l4.3 4.5L40 26.5"
        fill="none"
        stroke="#fff"
        stroke-width="5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </span>

{% elsif t == 'minus' %}
  <span class="compare__icon" aria-label="No">
    <svg viewBox="0 0 64 64" width="44" height="44" role="img" aria-hidden="true">
      <circle
        cx="32"
        cy="32"
        r="22"
        fill="none"
        stroke="{{ icon_muted_color }}"
        stroke-width="3"
      ></circle>
      <path
        d="M22 32h20"
        fill="none"
        stroke="{{ icon_muted_color }}"
        stroke-width="5"
        stroke-linecap="round"
      />
    </svg>
  </span>

{% else %}
  <span class="compare__icon" aria-hidden="true"></span>
{% endif %}
